# ------------------------------------------------------------------------------
# CrossChainEscrow — Deployment environment (EXAMPLE)
#
# Copy this file to `.env` and fill in real values. `.env` is gitignored.
# ------------------------------------------------------------------------------

# Deployer wallet private key (hex, 0x-prefixed). Becomes DEFAULT_ADMIN_ROLE.
PRIVATE_KEY=

# Arbiter wallet address. Granted ARBITER_ROLE (resolves disputes).
ARBITER_ADDRESS=

# Pauser wallet address (optional). Granted PAUSER_ROLE. Defaults to deployer.
PAUSER_ADDRESS=

# Arc Testnet RPC URL.
ARC_TESTNET_RPC_URL=https://rpc.testnet.arc.network
